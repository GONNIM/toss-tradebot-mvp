# 이 파일은 backend/.env.sops.yaml (SOPS 로 암호화) 의 **평문 스키마 예시** 입니다.
# 실제 값은 절대 여기에 넣지 마세요 — .example 만 커밋, 실 파일은 SOPS 로 편집.
#
# 최초 셋업 (한 번만):
#   1) brew install sops age
#   2) age-keygen -o ~/.config/sops/age/keys.txt
#      → 출력에서 public key(Public key: age1...) 를 복사
#   3) .sops.yaml 의 REPLACE_ME_WITH_AGE_PUBLIC_KEY 를 실제 public key 로 교체
#   4) 이 파일을 복사해서 시작:
#         cp backend/.env.sops.yaml.example backend/.env.sops.yaml
#         sops -e -i backend/.env.sops.yaml
#      → 이제 backend/.env.sops.yaml 은 암호화 상태 (git 커밋 안전)
#   5) 편집: sops edit backend/.env.sops.yaml
#      → 임시 tmpfs 에 평문으로 뜸 → 저장 시 자동 재암호화
#   6) GitHub Secret SOPS_AGE_KEY 등록:
#         gh secret set SOPS_AGE_KEY < ~/.config/sops/age/keys.txt
#
# 상세 절차: docs/operations/secrets-management.md

# ─── Toss Open API (자동매매 코어 · v2 트랙 C · 2026-07-10 Toss 전환) ───
# 상세: docs/plans/tradebot-mvp-v2/03-toss-openapi-integration.md
# accountSeq 확보: python -m scripts.toss.bootstrap_account
TOSS_CLIENT_ID: ""
TOSS_CLIENT_SECRET: ""
TOSS_ACCOUNT_SEQ: ""     # GET /api/v1/accounts 응답의 accountSeq (정수 · X-Tossinvest-Account 헤더 값)

# ─── Discovery LLM (3-provider) ───
ZAI_API_KEY: ""
ZAI_MODEL: "glm-4.5-flash"
OPENAI_API_KEY: ""
ANTHROPIC_API_KEY: ""
LLM_PROVIDER: "zai"

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN: ""
TELEGRAM_CHAT_ID: ""

# ─── Finnhub ───
FINNHUB_API_KEY: ""

# ─── DART ───
DART_API_KEY: ""

# ─── DB ───
DATABASE_URL: "sqlite:///./data/tradebot.db"

# ─── Backend↔Frontend 통신 ───
INTERNAL_API_KEY: ""

# ─── 실행 모드 ───
RUN_MODE: "PROD"

# ─── VIP 개별 감시 채널 (P-A) ───
VIP_ENABLED: "false"
VIP_TICKER: "WEN.O"
VIP_COMPANY_NAME: "Wendy's"
VIP_TAG: ""
VIP_AVG_PRICE: "0.00"
VIP_QTY: "0"
VIP_TP1_PCT: "0.07"
VIP_TP2_PCT: "0.15"
VIP_STOP_PCT: "-0.05"
VIP_TRAIL_ARM_PCT: "0.10"
VIP_TRAIL_GIVEBACK_PCT: "0.03"
VIP_POLL_SEC_MARKET: "30"
VIP_POLL_SEC_AFTER: "300"
VIP_ACTIVIST_ENABLED: "false"
VIP_ACTIVIST_CIK: "0001345471"
VIP_ACTIVIST_NAME: "Trian Partners"
VIP_ACTIVIST_KEYWORDS: "WEN,WENDY"
VIP_ACTIVIST_POLL_SEC: "300"
SEC_EDGAR_UA: "Suauncle-Research suauncle-contact@gmail.com"

# ─── 급등주 스나이퍼 (Sprint 1 · 2026-07-11) ───
# 상세: docs/plans/sniper/00-sprint1-plan.md
# 안전 원칙 · 프로덕션 초기엔 LIVE_ENABLED=false 유지 · forward test 통과 후 활성.
SNIPER_ENABLED: "true"           # 스케줄러 잡 등록 (안전 · 기본 true)
SNIPER_LIVE_ENABLED: "false"     # 편집·실주문 API 활성 (초기 false · forward test 후 true)
SNIPER_API_TOKEN: ""             # openssl rand -base64 32 로 생성 · 32자 랜덤 필수
PAPER_INITIAL_CASH: "1000000"    # Paper Adapter 초기 자본 (SNIPER seed_cap_krw 정합)

# ─── Watchlist 야간 신호 수집 (Sprint 2 · 2026-07-13) ───
# 상세: docs/plans/sniper/02-strategic-pivot-as-is-to-be.md
WATCHLIST_ENABLED: "true"        # 뉴스·종토방·YouTube·국회·정부 야간 축적 잡 활성
YOUTUBE_API_KEY: ""              # Google Cloud Console 발급 · quota 10000/day
YOUTUBE_CHANNELS: ""             # JSON override (선택) · 기본: 슈카·삼프로
ASSEMBLY_API_KEY: ""             # open.assembly.go.kr 인증키 (선택)
GOV_RSS_SOURCES: ""              # JSON override (선택) · 산업부·과기부 URL 확인 후

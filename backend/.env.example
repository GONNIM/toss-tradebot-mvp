# Toss Tradebot Backend — Environment Variables Template
#
# 실 .env 파일은 chmod 600. git 추적 X (.gitignore 13행).
# 본 .env.example 은 placeholder만 — 실제 값 입력 절대 금지.
# 글로벌 가드레일 (~/.claude-profiles/naver/CLAUDE.md §1) 준수.

# ─── Toss Open API (자동매매 코어 전용 — Phase K) ───
# 출처: developers.tossinvest.com 사전 신청 후 발급 (사용자 사전 신청 완료 2026-06-17)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_ID=

# ─── Discovery LLM thesis (3-provider 병행 — 결정 2026-06-19) ───
# 셋 다 채울 수 있고, LLM_PROVIDER 환경변수로 전환:
#   LLM_PROVIDER=zai        (기본) — glm-4.5-flash 무료 / glm-4.6 ~$0.3/월
#   LLM_PROVIDER=openai     — gpt-5-mini ~$0.5-1/월
#   LLM_PROVIDER=anthropic  — claude-haiku-4-5 ~$5-15/월
# 모델 override: ZAI_MODEL / OPENAI_MODEL / ANTHROPIC_MODEL
# Z.ai 출처: https://z.ai → API Keys 발급 (free tier 사용 가능)
ZAI_API_KEY=
ZAI_MODEL=glm-4.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=zai

# ─── Telegram Bot API (알림) ───
# 출처: BotFather (사용자 upbit 자산 재활용)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 소셜 sentiment (ApeWisdom — 무인증, 결정 2026-06-19) ───
# Reddit 정책 변경 (2025-11-11 Responsible Builder Policy 사전 승인 2-4주) 으로
# Reddit PRAW 직접 호출 대체. ApeWisdom 은 무료·무인증 → 별도 .env 변수 불필요.
# 향후 Reddit 직접 인증 필요 시 REDDIT_CLIENT_ID/SECRET 추가 (현재는 사용 안 함).

# ─── Finnhub Free Tier (Discovery 어닝 캘린더·애널리스트) ───
# 출처: finnhub.io 무료 가입 (60 req/min)
FINNHUB_API_KEY=

# ─── DB ───
DATABASE_URL=sqlite:///./data/tradebot.db

# ─── Backend ↔ Frontend 통신 (결정 38·42) ───
INTERNAL_API_KEY=

# 실행 모드: PROD / DEV / TEST
RUN_MODE=DEV

# ─── VIP 개별 감시 채널 (밈주 워치 P-A · 종목 파라미터화 · 2026-07-08) ───
# 상세: docs/plans/meme-stock-discovery/05-wen-vip-watch.md
# VIP_ENABLED=false 또는 VIP_AVG_PRICE=0 이면 감시 비활성 (엔진 skip).
# 임계값 pct 는 fraction (0.07 = +7%). 손절은 음수 (-0.05 = -5%).
# 종목 전환 시: VIP_TICKER / VIP_COMPANY_NAME / VIP_AVG_PRICE / VIP_QTY 만 교체.
# activist 파라미터는 UI /vip 페이지에서 편집 가능 (data/vip_overrides.json).
VIP_ENABLED=false
VIP_TICKER=WEN.O
VIP_COMPANY_NAME=Wendy's
VIP_TAG=
VIP_AVG_PRICE=0.00
VIP_QTY=0
VIP_TP1_PCT=0.07
VIP_TP2_PCT=0.15
VIP_STOP_PCT=-0.05
VIP_TRAIL_ARM_PCT=0.10
VIP_TRAIL_GIVEBACK_PCT=0.03
VIP_POLL_SEC_MARKET=30
VIP_POLL_SEC_AFTER=300
# ── Activist (SEC 필링) 트래커 — 선택 활성
# 종목마다 activist 존재 여부 다름. enabled=false 면 tick 즉시 skip.
# CIK 는 SEC EDGAR 조회 (예: Trian Fund Management L.P. = 0001345471).
# KEYWORDS 는 filing description 매치 문자열 (콤마 구분, 대소문자 무시).
# UI /vip 편집 폼으로 재시작 없이 변경 가능 (data/vip_overrides.json 우선).
VIP_ACTIVIST_ENABLED=false
VIP_ACTIVIST_CIK=0001345471
VIP_ACTIVIST_NAME=Trian Partners
VIP_ACTIVIST_KEYWORDS=WEN,WENDY
VIP_ACTIVIST_POLL_SEC=300
# SEC EDGAR data.sec.gov 요구 UA 형식: "Sample Company Name AdminContact@samplecompany.com"
SEC_EDGAR_UA=Suauncle-Research suauncle-contact@gmail.com

# ─── Activist Radar 알림 우선순위 (2026-07-09~) ───
# URGENT: REGIME_CHANGE · CRITICAL · CRITICAL_PACK · 🚨
# NORMAL: STRONG · STRONG_PACK · PACK · INSIDER(매수) · 🔔
# INFO:   INSIDER(매도) · WATCH · 📎
# SKIP:   NOTE · Form 4 non-trade (옵션·수여) — 항상 미발송
# min_level 이상 발송. 기본 NORMAL (INFO/WATCH/매도 알림 skip).
ACTIVIST_ALERT_MIN_LEVEL=NORMAL

# ─── CORS 화이트리스트 (2026-07-08 환경변수화, 교훈 #1 관련) ───
# 쉼표(,) 로 여러 origin 구분. 앞뒤 공백은 자동 trim.
# 미설정 시 기본값 (로컬 dev 3000/4000/5000 + 127.0.0.1:4000 + optimus8) 사용.
# 프론트 포트 변경 시 이 값만 수정 → 백엔드 재기동 (uvicorn --reload 자동 감지).
# 예:
#   CORS_ORIGINS=http://localhost:4000,https://optimus8.cafe24.com
#   CORS_ORIGINS=http://localhost:6000,http://staging.example.com
CORS_ORIGINS=

# ─── Execution Layer — Broker Adapter Pattern (v2 트랙 C · 2026-07-10 Toss 전환) ───
# 상세: docs/plans/tradebot-mvp-v2/01-track-c-roadmap.md
#       docs/plans/tradebot-mvp-v2/02-omi-interface-spec.md
#       docs/plans/tradebot-mvp-v2/03-toss-openapi-integration.md
#
# 실행 마스터 스위치. false 면 시그널 → 알림 흐름은 기존과 동일하되
# Order Manager 라우팅은 완전 비활성 (기존 동작 100% 호환).
EXECUTION_ENABLED=false
# 브로커 선택: paper | toss
#   paper — 시뮬 어댑터 (실 시세 + 가상 체결 · Phase 1)
#   toss  — Toss Open API 실전 어댑터 (Phase 2~)
EXECUTION_BROKER=paper
# 종목당 1회 최대 주문 금액 (원 · KR 기준). 실전 소액 검증 하드 상한.
EXECUTION_MAX_ORDER_AMOUNT=100000
# 일일 총 손실 캡 (fraction). 초과 시 Kill Switch 자동 발동.
EXECUTION_DAILY_LOSS_LIMIT=-0.03
# 종목별 Max Drawdown 캡 (fraction). 초과 시 해당 티커 자동 청산.
EXECUTION_TICKER_DD_LIMIT=-0.05
# 종목당 최대 자본 할당 비율 (fraction of total capital).
EXECUTION_PER_TICKER_MAX_PCT=0.10
# Signal Router → Order Manager 통합 로그 수준 (DEBUG/INFO/WARNING/ERROR)
EXECUTION_LOG_LEVEL=INFO

# ─── Toss Open API v1.2.2 (v2 트랙 C · Phase 2 실전 어댑터) ───
# 출처: https://developers.tossinvest.com/docs
# Base: https://openapi.tossinvest.com  (OAuth2 CC + X-Tossinvest-Account 헤더)
# 발급 절차: 토스증권 WTS → 설정 > Open API → client_id/secret 발급 + 허용 IP 등록
# 사용자 API 키 발급 완료(2026-07-10).
# 상세: docs/plans/tradebot-mvp-v2/03-toss-openapi-integration.md
#
# 클라이언트 인증 (상단 Phase K 스키마 재사용 · 값만 새 키로 채움)
#   TOSS_CLIENT_ID / TOSS_CLIENT_SECRET 는 파일 상단에 이미 정의됨.
# 계좌 식별 (GET /api/v1/accounts 응답의 accountSeq 를 사용 — 정수)
TOSS_ACCOUNT_SEQ=
# Access Token 캐시 파일 (자동 재발급 · 만료 5분 전 갱신)
TOSS_TOKEN_CACHE_PATH=data/toss_token.json
# 허용 IP 등록 여부 검증 (등록 필수 · 미등록 시 403 forbidden)
# 서버 배포 IP 를 developers.tossinvest.com 허용 IP 목록에 반드시 등록.
TOSS_ALLOWED_IP_NOTE=optimus8.cafe24.com 서버 IP 등록 필요
# 클라이언트 주문 멱등키 프리픽스 (10분 유효 · 36자 이내 · [a-zA-Z0-9_-])
TOSS_CLIENT_ORDER_PREFIX=ttb

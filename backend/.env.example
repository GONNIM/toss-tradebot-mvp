# Toss Tradebot Backend — Environment Variables Template
#
# 실 .env 파일은 chmod 600. git 추적 X (.gitignore 13행).
# 본 .env.example 은 placeholder만 — 실제 값 입력 절대 금지.
# 글로벌 가드레일 (~/.claude-profiles/naver/CLAUDE.md §1) 준수.

# ─── Toss Open API (자동매매 코어 전용 — Phase K) ───
# 출처: developers.tossinvest.com 사전 신청 후 발급 (사용자 사전 신청 완료 2026-06-17)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_ID=

# ─── Discovery LLM thesis (3-provider 병행 — 결정 2026-06-19) ───
# 셋 다 채울 수 있고, LLM_PROVIDER 환경변수로 전환:
#   LLM_PROVIDER=zai        (기본) — glm-4.5-flash 무료 / glm-4.6 ~$0.3/월
#   LLM_PROVIDER=openai     — gpt-5-mini ~$0.5-1/월
#   LLM_PROVIDER=anthropic  — claude-haiku-4-5 ~$5-15/월
# 모델 override: ZAI_MODEL / OPENAI_MODEL / ANTHROPIC_MODEL
# Z.ai 출처: https://z.ai → API Keys 발급 (free tier 사용 가능)
ZAI_API_KEY=
ZAI_MODEL=glm-4.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=zai

# ─── Telegram Bot API (알림) ───
# 출처: BotFather (사용자 upbit 자산 재활용)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 소셜 sentiment (ApeWisdom — 무인증, 결정 2026-06-19) ───
# Reddit 정책 변경 (2025-11-11 Responsible Builder Policy 사전 승인 2-4주) 으로
# Reddit PRAW 직접 호출 대체. ApeWisdom 은 무료·무인증 → 별도 .env 변수 불필요.
# 향후 Reddit 직접 인증 필요 시 REDDIT_CLIENT_ID/SECRET 추가 (현재는 사용 안 함).

# ─── Finnhub Free Tier (Discovery 어닝 캘린더·애널리스트) ───
# 출처: finnhub.io 무료 가입 (60 req/min)
FINNHUB_API_KEY=

# ─── DB ───
DATABASE_URL=sqlite:///./data/tradebot.db

# ─── Backend ↔ Frontend 통신 (결정 38·42) ───
INTERNAL_API_KEY=

# 실행 모드: PROD / DEV / TEST
RUN_MODE=DEV

# Toss Tradebot Frontend — Environment Variables Template
#
# 실 .env.local 파일은 chmod 600. git 추적 X.
# 본 .env.example 은 placeholder만.

# ─── Backend FastAPI 통신 (결정 42) ───
# 로컬 개발 시: http://localhost:8000
# 운영 (optimus8): https://optimus8.cafe24.com (Nginx reverse proxy)
NEXT_PUBLIC_API_BASE_URL=

# Backend ↔ Frontend 내부 인증 (서버 .env 의 INTERNAL_API_KEY 와 동일)
INTERNAL_API_KEY=

# ─── NextAuth.js (결정 38) ───
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ─── Google OAuth (결정 38) ───
# 출처: console.cloud.google.com → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 화이트리스트 (결정 38) ───
# 본인 Gmail 1개만 허용 — 외부인 차단
ALLOWED_EMAIL=suauncle@gmail.com
